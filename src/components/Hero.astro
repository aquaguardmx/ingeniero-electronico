---
---

<section class="relative min-h-screen overflow-hidden pt-24">
  <!-- Grid / circuit background -->
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(34,211,238,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(34,211,238,0.03)_1px,transparent_1px)] bg-[size:4rem_4rem]"
  >
  </div>
  <div
    class="absolute right-0 top-1/4 h-96 w-96 rounded-full bg-cyan-500/10 blur-3xl"
  >
  </div>
  <div
    class="absolute bottom-1/4 left-0 h-80 w-80 rounded-full bg-amber-500/10 blur-3xl"
  >
  </div>

  <div
    class="relative mx-auto flex max-w-6xl flex-col items-center justify-center px-4 py-32 text-center md:py-40"
  >
    <p class="font-heading text-sm uppercase tracking-[0.3em] text-cyan-400">
      Sistemas · Mecánica · Eléctrica
    </p>
    <h1
      class="font-heading mt-4 text-4xl font-bold tracking-tight text-white md:text-6xl lg:text-7xl"
    >
      Día del Ingeniero <span
        class="bg-gradient-to-r from-cyan-400 to-amber-400 bg-clip-text text-transparent"
        >Electronica</span
      >
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-slate-400">
      Equipo de estudiantes de ingeniería en sistemas, mecánica y eléctrica.
      Eventos, proyectos y contacto.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="#equipo"
        class="rounded-lg bg-cyan-500 px-6 py-3 font-semibold text-slate-900 transition hover:bg-cyan-400"
      >
        Conocer equipo
      </a>
      <a
        href="#eventos-proximos"
        class="rounded-lg border border-slate-600 px-6 py-3 font-semibold text-slate-300 transition hover:border-cyan-500 hover:text-cyan-400"
      >
        Ver eventos
      </a>
    </div>
  </div>
</section>
