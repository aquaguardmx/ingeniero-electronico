---
import { pastEvents } from '../data/events';
---

<section id="eventos-pasados" class="relative border-t border-slate-700/50 bg-slate-900/30 py-24">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <h2 class="font-heading text-center text-3xl font-bold text-white md:text-4xl">
      Eventos <span class="text-emerald-400">realizados</span>
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-slate-400">
      Haz clic en un evento para ver la galería de fotos.
    </p>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 md:gap-8">
      {pastEvents.map((event) => (
        <button
          type="button"
          class="event-past-card group relative flex min-h-[200px] flex-col items-center justify-center overflow-hidden rounded-2xl border border-slate-700/50 bg-gradient-to-br from-slate-800/40 to-slate-900/60 p-6 text-center transition-all duration-300 hover:-translate-y-1 hover:border-cyan-500/50 hover:shadow-xl hover:shadow-cyan-500/20"
          data-event-id={event.id}
          data-event-title={event.title}
          data-event-images={JSON.stringify(event.images)}
        >
          <!-- Fondo decorativo al pasar el cursor -->
          <div class="absolute inset-0 bg-cyan-500/5 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          
          <h3 class="relative z-10 font-heading text-xl font-bold tracking-wide text-white transition-transform duration-300 group-hover:-translate-y-2 group-hover:text-cyan-300 md:text-2xl">
            {event.title}
          </h3>
          
          <span class="absolute bottom-6 left-0 z-10 w-full translate-y-4 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
            <span class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-cyan-400">
              Ver galería
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </span>
          </span>
        </button>
      ))}
    </div>
  </div>

  <!-- Modal Galería (Carrusel) -->
  <div
    id="gallery-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/95 p-4 backdrop-blur-md transition-opacity"
    role="dialog"
    aria-modal="true"
    aria-label="Galería de fotos"
  >
    <div class="relative w-full max-w-5xl">
      <!-- Encabezado Modal -->
      <div class="mb-4 flex items-center justify-between">
        <h3 id="gallery-title" class="font-heading text-xl font-bold text-white md:text-2xl"></h3>
        <button
          type="button"
          id="gallery-close"
          class="rounded-full bg-slate-800/80 p-2 text-slate-300 transition-colors hover:bg-red-500/20 hover:text-red-400"
          aria-label="Cerrar galería"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Carrusel -->
      <div class="group relative flex aspect-video w-full items-center justify-center overflow-hidden rounded-2xl bg-slate-900/80 shadow-2xl ring-1 ring-slate-700/50">
        <!-- Imagen -->
        <img id="carousel-img" src="" alt="Foto del evento" class="max-h-full max-w-full object-contain transition-opacity duration-200" />
        
        <!-- Controles -->
        <button id="carousel-prev" class="absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-black/60 p-3 text-white backdrop-blur-sm transition-all hover:scale-110 hover:bg-cyan-500/80 focus:outline-none md:left-6 md:p-4">
          <svg class="h-6 w-6 md:h-8 md:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="carousel-next" class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-black/60 p-3 text-white backdrop-blur-sm transition-all hover:scale-110 hover:bg-cyan-500/80 focus:outline-none md:right-6 md:p-4">
          <svg class="h-6 w-6 md:h-8 md:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </button>

        <!-- Indicador texto -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full bg-black/70 px-4 py-1.5 text-sm font-medium tracking-wide text-white backdrop-blur-md">
          <span id="carousel-counter">1 / 1</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  let currentImages: string[] = [];
  let currentIndex = 0;

  const modal = document.getElementById('gallery-modal');
  const titleEl = document.getElementById('gallery-title');
  const carouselImg = document.getElementById('carousel-img') as HTMLImageElement | null;
  const counterEl = document.getElementById('carousel-counter');
  const btnPrev = document.getElementById('carousel-prev');
  const btnNext = document.getElementById('carousel-next');

  function updateCarousel() {
    if (currentImages.length > 0 && carouselImg && counterEl) {
      // Pequeña animación de desvanecimiento
      carouselImg.style.opacity = '0.3';
      setTimeout(() => {
        carouselImg.setAttribute('src', currentImages[currentIndex]);
        carouselImg.style.opacity = '1';
        counterEl.textContent = `${currentIndex + 1} / ${currentImages.length}`;
      }, 150);
      
      const showControls = currentImages.length > 1;
      if (btnPrev && btnNext) {
        btnPrev.style.display = showControls ? 'block' : 'none';
        btnNext.style.display = showControls ? 'block' : 'none';
      }
    }
  }

  function nextImage() {
    if (currentImages.length <= 1) return;
    currentIndex = (currentIndex + 1) % currentImages.length;
    updateCarousel();
  }

  function prevImage() {
    if (currentImages.length <= 1) return;
    currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
    updateCarousel();
  }

  document.querySelectorAll('.event-past-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      const title = btn.getAttribute('data-event-title');
      const imagesJson = btn.getAttribute('data-event-images');
      if (!title || !imagesJson) return;
      
      currentImages = JSON.parse(imagesJson);
      currentIndex = 0;

      if (!modal || !titleEl || !carouselImg) return;

      titleEl.textContent = title;
      updateCarousel();

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  btnNext?.addEventListener('click', (e) => {
    e.stopPropagation();
    nextImage();
  });
  
  btnPrev?.addEventListener('click', (e) => {
    e.stopPropagation();
    prevImage();
  });

  function closeModal() {
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
      currentImages = [];
    }
  }

  document.getElementById('gallery-close')?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (!modal || modal.classList.contains('hidden')) return;
    
    if (e.key === 'Escape') closeModal();
    if (e.key === 'ArrowRight') nextImage();
    if (e.key === 'ArrowLeft') prevImage();
  });
</script>
