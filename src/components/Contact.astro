---
import { teamMembers } from '../data/team';

const carreraColors: Record<string, string> = {
  Sistemas: 'text-emerald-400',
  Mecánica: 'text-amber-400',
  Eléctrica: 'text-cyan-400',
};
---
<section id="contacto" class="relative border-t border-slate-700/50 py-24">
  <div class="absolute inset-0 bg-[linear-gradient(rgba(34,211,238,0.02)_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>
  <div class="relative mx-auto max-w-6xl px-4 md:px-6">
    <h2 class="font-heading text-center text-3xl font-bold text-white md:text-4xl">
      <span class="text-cyan-400">Contacto</span>
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-slate-400">
      Estudiantes y asesora del equipo. Escríbenos para más información.
    </p>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {teamMembers.map((member) => (
        <div
          class={`rounded-2xl border bg-slate-800/50 p-6 ${
            member.isAdvisor ? 'border-amber-500/30' : 'border-slate-700/50'
          }`}
        >
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-slate-700 font-heading text-lg font-bold text-cyan-400">
              {member.name.charAt(0)}
            </div>
            <div>
              <h3 class="font-heading font-semibold text-white">{member.name}</h3>
              <p class={`text-sm font-medium ${carreraColors[member.carrera]}`}>{member.carrera}</p>
              {member.isAdvisor && <span class="text-xs text-amber-400">Asesora</span>}
            </div>
          </div>
          <div class="mt-4 space-y-2">
            {member.email && (
              <a
                href={`mailto:${member.email}`}
                class="flex items-center gap-2 text-sm text-slate-400 transition hover:text-cyan-400"
              >
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                {member.email}
              </a>
            )}
            {member.linkedin && (
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-slate-400 transition hover:text-cyan-400"
              >
                <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
